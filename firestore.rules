rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── Users Collection & Subcollections ─────────────────────────────────────
    // Users need client-side access to read/write their profile and any subcollections
    // nested under their user document to support real-time sync (onSnapshot).
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
